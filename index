<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Festi'Run 2027</title>
<meta name="description" content="Festi'Run 2027 - Course solidaire et inclusive organisée par APF France handicap.">
<style>
:root{
--pink:#e5007e;--blue:#00a0df;--dark:#16324f;--bg:#f4f7fb;
}
*{box-sizing:border-box}
body{margin:0;font-family:Arial,sans-serif;background:var(--bg);color:#222;line-height:1.6}
.hero{
background:linear-gradient(rgba(22,50,79,.75),rgba(22,50,79,.75)),url('hero.jpg') center/cover;
min-height:85vh;color:#fff;display:flex;align-items:center;text-align:center
}
.container{width:min(1200px,92%);margin:auto}
.logo{max-width:180px}
h1{font-size:4rem;margin:.5rem 0}
.btn{display:inline-block;background:var(--pink);color:#fff;padding:14px 24px;border-radius:10px;text-decoration:none}
.grid{display:grid;gap:24px}
.stats{grid-template-columns:repeat(auto-fit,minmax(200px,1fr));margin-top:-50px}
.card{background:#fff;padding:24px;border-radius:18px;box-shadow:0 8px 20px rgba(0,0,0,.08)}
section{padding:70px 0}
h2{text-align:center;color:var(--dark);margin-bottom:30px}
.parcours,.features,.activities,.gallery{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px}
.gallery img{width:100%;height:240px;object-fit:cover;border-radius:12px;background:#ddd}
.timeline{max-width:800px;margin:auto;border-left:4px solid var(--blue);padding-left:25px}
.timeline div{background:#fff;margin:15px 0;padding:15px;border-radius:12px}
.countdown{display:flex;justify-content:center;gap:12px;flex-wrap:wrap;margin-top:20px}
.countdown div{background:#fff;color:var(--dark);padding:15px;border-radius:12px;min-width:90px}
.countdown strong{display:block;font-size:1.8rem}
.video,.map{position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:16px}
.video iframe,.map iframe{position:absolute;inset:0;width:100%;height:100%;border:0}
.form-wrap{background:linear-gradient(135deg,var(--pink),var(--blue));padding:40px;border-radius:20px}
form{background:#fff;padding:25px;border-radius:16px;display:grid;gap:15px}
input,select{padding:12px;border:1px solid #ccc;border-radius:8px}
button{background:var(--pink);color:#fff;border:none;padding:14px;border-radius:8px}
footer{background:var(--dark);color:#fff;padding:40px 0}
footer a{color:#fff}
@media(max-width:768px){h1{font-size:2.4rem}}
</style>
</head>
<body>

<header class="hero">
<div class="container">
<img src="logo.png" class="logo" alt="Festi'Run">
<h1>Festi'Run 2027</h1>
<p>13 juin 2027 • Bois de Vincennes • Esplanade Saint‑Louis</p>
<div class="countdown">
<div><strong id="d">0</strong>Jours</div>
<div><strong id="h">0</strong>Heures</div>
<div><strong id="m">0</strong>Minutes</div>
<div><strong id="s">0</strong>Secondes</div>
</div>
</div>
</header>

<section>
<div class="container grid stats">
<div class="card"><h3>1500+</h3><p>Participants</p></div>
<div class="card"><h3>4</h3><p>Parcours</p></div>
<div class="card"><h3>20+</h3><p>Animations</p></div>
<div class="card"><h3>100%</h3><p>Inclusif</p></div>
</div>
</section>

<section>
<div class="container">
<h2>Pourquoi participer ?</h2>
<div class="features">
<div class="card"><h3>Courir ou marcher</h3><p>Des parcours accessibles à tous.</p></div>
<div class="card"><h3>Découvrir</h3><p>Le sport inclusif et les activités adaptées.</p></div>
<div class="card"><h3>Soutenir</h3><p>Les actions d'APF France handicap.</p></div>
<div class="card"><h3>Partager</h3><p>Une journée conviviale et festive.</p></div>
</div>
</div>
</section>

<section>
<div class="container">
<h2>Les parcours</h2>
<div class="parcours">
<div class="card"><h3>3 km</h3><p>Découverte</p></div>
<div class="card"><h3>5 km</h3><p>Solidaire</p></div>
<div class="card"><h3>10 km</h3><p>Loisir</p></div>
<div class="card"><h3>10 km</h3><p>Chronométré</p></div>
</div>
</div>
</section>

<section>
<div class="container">
<h2>Programme</h2>
<div class="timeline">
<div>07h30 • Ouverture du village</div>
<div>08h00 • Retrait des dossards</div>
<div>08h30 • Échauffement collectif</div>
<div>10h00 • Départ du 10 km</div>
<div>10h10 • Départ du 5 km</div>
<div>10h20 • Départ du 3 km</div>
<div>12h00 • Remise des récompenses</div>
<div>13h30 • Clôture</div>
</div>
</div>
</section>

<section>
<div class="container">
<h2>Village inclusif</h2>
<div class="activities">
<div class="card">Tennis fauteuil</div>
<div class="card">Basket fauteuil</div>
<div class="card">Biathlon adapté</div>
<div class="card">Drone soccer</div>
<div class="card">Joëlettes</div>
<div class="card">Sensibilisation au handicap</div>
</div>
</div>
</section>

<section>
<div class="container">
<h2>Galerie</h2>
<div class="gallery">
<img src="photo1.jpg" alt="Photo FestiRun 1">
<img src="photo2.jpg" alt="Photo FestiRun 2">
<img src="photo3.jpg" alt="Photo FestiRun 3">
<img src="photo4.jpg" alt="Photo FestiRun 4">
<img src="photo5.jpg" alt="Photo FestiRun 5">
<img src="photo6.jpg" alt="Photo FestiRun 6">
</div>
</div>
</section>

<section><div class="container"><h2>Vidéo</h2><div class="video"><iframe src="https://www.youtube.com/embed/kiZs5OwgMgs" allowfullscreen></iframe></div></div></section>

<section><div class="container"><h2>Accès</h2><div class="map"><iframe src="https://maps.google.com/maps?q=Chateau%20de%20Vincennes&t=&z=15&output=embed"></iframe></div></div></section>

<section><div class="container" style="text-align:center"><a class="btn" href="programme.pdf">Télécharger le programme</a></div></section>

<section>
<div class="container">
<div class="form-wrap">
<h2 style="color:white">Inscription</h2>
<form id="f">
<input required placeholder="Nom">
<input required placeholder="Prénom">
<select required><option value="">Genre</option><option>Femme</option><option>Homme</option><option>Non-binaire</option><option>Autre</option></select>
<input required placeholder="Téléphone">
<label><input type="checkbox" required> J'accepte la politique de confidentialité.</label>
<label><input type="checkbox"> Je souhaite recevoir les actualités.</label>
<button type="submit">Valider mon inscription</button>
<div id="ok" style="display:none;color:green">Votre inscription a bien été enregistrée.</div>
</form>
</div>
</div>
</section>

<footer>
<div class="container">
<p>festirun@apf.asso.fr • 01 40 78 27 06</p>
<p>17 boulevard Auguste Blanqui, 75013 Paris</p>
<p><a href="https://www.apf-francehandicap.org/politique-confidentialite">Politique de confidentialité</a> | <a href="https://www.apf-francehandicap.org/mentions-legales">Mentions légales</a></p>
</div>
</footer>

<script>
const target=new Date("2027-06-13T07:30:00").getTime();
function tick(){
const n=Date.now(),x=target-n;if(x<0)return;
d.textContent=Math.floor(x/86400000);
h.textContent=Math.floor(x%86400000/3600000);
m.textContent=Math.floor(x%3600000/60000);
s.textContent=Math.floor(x%60000/1000);
}
tick();setInterval(tick,1000);
document.getElementById('f').addEventListener('submit',e=>{
e.preventDefault();
document.getElementById('ok').style.display='block';
e.target.reset();
});
</script>

</body>
</html>
