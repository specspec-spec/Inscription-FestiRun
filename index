```html
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Festi'Run 2027 | Course solidaire et inclusive</title>
<meta name="description" content="Participez au Festi'Run 2027 le 13 juin 2027 au Bois de Vincennes. Une journée sportive, festive et inclusive organisée par APF France handicap.">

<style>
:root{
    --rose:#e5007e;
    --bleu:#00a0df;
    --bleu-fonce:#183153;
    --gris:#f5f7fa;
    --texte:#2b2b2b;
    --blanc:#ffffff;
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{
    font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    color:var(--texte);
    background:var(--gris);
    line-height:1.6;
}

.container{
    width:min(1200px,92%);
    margin:auto;
}

section{
    padding:80px 0;
}

h2{
    text-align:center;
    margin-bottom:40px;
    font-size:2rem;
    color:var(--bleu-fonce);
}

.card{
    background:white;
    border-radius:20px;
    padding:30px;
    box-shadow:0 10px 30px rgba(0,0,0,.08);
}

.btn{
    display:inline-block;
    padding:15px 28px;
    border-radius:10px;
    text-decoration:none;
    font-weight:700;
    background:var(--rose);
    color:white;
    transition:.2s;
}

.btn:hover{
    transform:translateY(-2px);
}

/* HERO */

.hero{
    min-height:90vh;
    background:
    linear-gradient(rgba(24,49,83,.65),rgba(24,49,83,.65)),
    url("hero.jpg");
    background-size:cover;
    background-position:center;
    color:white;
    display:flex;
    align-items:center;
    text-align:center;
}

.hero-content{
    width:100%;
}

.hero img{
    max-width:180px;
    margin-bottom:25px;
}

.hero h1{
    font-size:4rem;
    margin-bottom:15px;
}

.hero p{
    font-size:1.3rem;
    max-width:900px;
    margin:auto;
}

.hero-meta{
    margin-top:30px;
    display:flex;
    justify-content:center;
    gap:20px;
    flex-wrap:wrap;
}

.meta{
    background:rgba(255,255,255,.15);
    backdrop-filter:blur(8px);
    padding:15px 25px;
    border-radius:12px;
}

/* COUNTDOWN */

.countdown{
    margin-top:40px;
    display:flex;
    justify-content:center;
    gap:15px;
    flex-wrap:wrap;
}

.time{
    background:white;
    color:var(--bleu-fonce);
    width:120px;
    padding:20px;
    border-radius:15px;
}

.time strong{
    display:block;
    font-size:2rem;
}

/* STATS */

.stats{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:25px;
}

.stat{
    background:white;
    text-align:center;
    padding:30px;
    border-radius:20px;
    box-shadow:0 10px 30px rgba(0,0,0,.08);
}

.stat-number{
    font-size:3rem;
    font-weight:700;
    color:var(--rose);
}

/* WHY */

.features{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
}

.feature{
    background:white;
    border-radius:20px;
    padding:30px;
    text-align:center;
}

/* PARCOURS */

.parcours{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:25px;
}

.parcours-card{
    background:white;
    border-radius:20px;
    padding:30px;
    text-align:center;
    border-top:8px solid var(--rose);
}

/* TIMELINE */

.timeline{
    position:relative;
    max-width:800px;
    margin:auto;
}

.timeline:before{
    content:"";
    position:absolute;
    left:20px;
    top:0;
    width:4px;
    height:100%;
    background:var(--bleu);
}

.timeline-item{
    margin-left:60px;
    margin-bottom:30px;
    background:white;
    padding:20px;
    border-radius:15px;
    position:relative;
}

.timeline-item:before{
    content:"";
    position:absolute;
    width:18px;
    height:18px;
    border-radius:50%;
    background:var(--rose);
    left:-49px;
    top:22px;
}

/* ACTIVITES */

.activities{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:20px;
}

.activity{
    background:white;
    padding:25px;
    border-radius:15px;
    text-align:center;
}

/* GALLERY */

.gallery{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:20px;
}

.gallery img{
    width:100%;
    height:250px;
    object-fit:cover;
    border-radius:15px;
}

/* VIDEO */

.video{
    position:relative;
    padding-bottom:56.25%;
    height:0;
    overflow:hidden;
    border-radius:20px;
}

.video iframe{
    position:absolute;
    width:100%;
    height:100%;
    border:none;
}

/* MAP */

.map{
    position:relative;
    padding-bottom:45%;
    height:0;
    overflow:hidden;
    border-radius:20px;
}

.map iframe{
    position:absolute;
    width:100%;
    height:100%;
    border:none;
}

/* FORM */

.form-section{
    background:linear-gradient(135deg,var(--rose),var(--bleu));
    color:white;
}

.form-card{
    background:white;
    color:black;
    max-width:800px;
    margin:auto;
    padding:40px;
    border-radius:20px;
}

form{
    display:grid;
    gap:18px;
}

input,
select{
    padding:14px;
    border:1px solid #ddd;
    border-radius:10px;
}

button{
    background:var(--rose);
    color:white;
    border:none;
    padding:16px;
    border-radius:10px;
    cursor:pointer;
    font-weight:700;
}

.checkbox{
    display:flex;
    gap:10px;
    align-items:flex-start;
}

.success{
    display:none;
    margin-top:20px;
    background:#e8f7ec;
    color:#156c2f;
    padding:15px;
    border-radius:10px;
}

/* FOOTER */

footer{
    background:var(--bleu-fonce);
    color:white;
    padding:50px 0;
}

footer a{
    color:white;
}

.footer-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:30px;
}

@media(max-width:768px){

.hero h1{
    font-size:2.5rem;
}

.time{
    width:90px;
}

.time strong{
    font-size:1.5rem;
}

}
</style>
</head>

